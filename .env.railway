# ========================================
# AI RAG Assistant - Railway Environment
# ========================================
# Copy this to your Railway backend service's environment variables.
# Railway auto-sets DATABASE_URL and REDIS_URL from plugins.

# App
ENVIRONMENT=production
SECRET_KEY=generate-a-random-secret-key-here

# Database (auto-set by Railway PostgreSQL plugin)
# DATABASE_URL=postgresql+asyncpg://...
# DATABASE_URL_SYNC=postgresql://...

# Redis (auto-set by Railway Redis plugin)
# REDIS_URL=redis://...

# MinIO (use Railway MinIO plugin or external)
MINIO_ENDPOINT=your-minio-endpoint:9000
MINIO_ACCESS_KEY=your-minio-access-key
MINIO_SECRET_KEY=your-minio-secret-key
MINIO_BUCKET=documents
MINIO_PUBLIC_URL=https://your-minio-endpoint

# LLM API Keys (AT LEAST ONE required)
ANTHROPIC_API_KEY=sk-ant-your-claude-api-key
OPENAI_API_KEY=sk-your-openai-api-key

# LLM Configuration
LLM_PROVIDER=claude
LLM_MODEL=claude-sonnet-4-20250514

# Embedding
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small

# Chunking
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# Vector Store
VECTOR_STORE=pgvector

# Rate Limit
RATE_LIMIT_PER_MINUTE=30
