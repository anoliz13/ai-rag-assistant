# App
PROJECT_NAME=AI RAG Assistant
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=change-me-in-production

# Database
DATABASE_URL=postgresql+asyncpg://raguser:ragpass@postgres:5432/ragdb
DATABASE_URL_SYNC=postgresql://raguser:ragpass@postgres:5432/ragdb

# Redis
REDIS_URL=redis://redis:6379/0

# MinIO
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=documents
MINIO_PUBLIC_URL=http://localhost:9000

# LLM API Keys
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
LLM_PROVIDER=claude  # claude | openai
LLM_MODEL=claude-sonnet-4-20250514  # or gpt-4o

# Embedding
EMBEDDING_PROVIDER=openai  # openai | local
EMBEDDING_MODEL=text-embedding-3-small  # or all-MiniLM-L6-v2

# Chunking
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# Vector Store
VECTOR_STORE=pgvector  # pgvector | chroma

# Rate Limit
RATE_LIMIT_PER_MINUTE=30

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
